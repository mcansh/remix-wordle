{
  "name": "remix-wordle",
  "private": true,
  "description": "a wordle game made with Remix",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "build": "remix vite:build",
    "dev": "cross-env TZ=UTC node --require ./mocks/index.cjs --watch ./server.js ./server.js",
    "start": "cross-env TZ=UTC node ./server.cjs",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "format": "prettier --write --ignore-path .gitignore .",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@mcansh/http-helmet": "^0.13.2",
    "@mcansh/remix-fastify": "^4.1.2",
    "@prisma/client": "^7.2.0",
    "@remix-run/node": "^2.17.3",
    "@remix-run/react": "^2.17.3",
    "@remix-run/serve": "^2.17.3",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.66.4",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "fastify": "^5.6.2",
    "get-port": "^7.1.0",
    "ioredis": "^5.9.1",
    "isbot": "^5.1.32",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "remix-utils": "^9.0.0",
    "type-fest": "^5.3.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@remix-run/dev": "^2.17.3",
    "@remix-run/eslint-config": "^2.17.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prefer-let": "^4.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.7",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-100vh-fix": "^2.0.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.2.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.7.0"
}
