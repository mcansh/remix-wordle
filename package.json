{
  "name": "remix-wordle",
  "private": true,
  "description": "a wordle game made with Remix",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "build": "remix vite:build",
    "dev": "cross-env TZ=UTC node --require ./mocks/index.cjs --watch ./server.js ./server.js",
    "start": "cross-env TZ=UTC node ./server.cjs",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "format": "prettier --write --ignore-path .gitignore .",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@mcansh/http-helmet": "^0.10.3",
    "@mcansh/remix-fastify": "^3.4.0",
    "@prisma/client": "^5.19.0",
    "@remix-run/node": "^2.11.2",
    "@remix-run/react": "^2.11.2",
    "@remix-run/serve": "^2.11.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.12",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "date-fns": "^3.6.0",
    "fastify": "^4.28.1",
    "get-port": "^7.1.0",
    "ioredis": "^5.4.1",
    "isbot": "^5.1.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remix-utils": "^7.6.0",
    "type-fest": "^4.26.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.11.2",
    "@remix-run/eslint-config": "^2.11.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.47.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-prefer-let": "^4.0.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.5",
    "lint-staged": "^15.2.10",
    "msw": "^2.4.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.44",
    "postcss-100vh-fix": "^1.0.2",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "prisma": "^5.19.0",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.21",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.3+sha512.d08425c8062f56d43bb8e84315864218af2492eb769e1f1ca40740f44e85bd148969382d651660363942e5909cb7ffcbef7ca0ae963ddc2c57a51243b4da8f56"
